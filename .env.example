# ============================================================
#  חיבור API-Football (אופציונלי) — לתוצאות חיות + פציעות אוטומטיות
# ============================================================
# המערכת עובדת מצוין גם בלי זה (נתונים פתוחים + הזנה ידנית).
# כדי לקבל עדכון אוטומטי של תוצאות ופציעות:
#
# 1. היכנס ל-https://dashboard.api-football.com/register  (הרשמה חינמית)
# 2. אמת את המייל, ובלוח הבקרה העתק את ה-API Key.
# 3. העתק קובץ זה ל-.env (באותה תיקייה) ומלא את המפתח למטה.
# 4. הפעל מחדש את התוכנה ולחץ "רענן נתונים עכשיו".
#
# המסלול החינמי = 100 בקשות ביום. המערכת שומרת cache ולא חורגת.
# המפתח נשמר רק כאן, במחשב שלך. אל תעלה את .env לשום מקום ציבורי.

API_FOOTBALL_KEY=
API_FOOTBALL_PROVIDER=apisports
